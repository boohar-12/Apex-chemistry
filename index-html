<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Apex Academy Chemistry | Sir Nasarullah</title>
    <meta name="description" content="Concept-Based Chemistry Learning for School & College Students by Sir Nasarullah (BS Chemistry). Master chemistry with confidence.">
    <meta name="keywords" content="Apex Academy Chemistry, Sir Nasarullah, Chemistry Teacher Pakistan, Online Chemistry Notes, Class 9, Class 10, First Year, Second Year Chemistry">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- FontAwesome for Premium Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        /* ==========================================================================
           1. SETUP & THEME VARIABLES
           ========================================================================== */
        :root {
            --bg-deep-navy: #0a0f1d;
            --bg-card-glass: rgba(16, 24, 48, 0.65);
            --border-glass: rgba(0, 242, 254, 0.15);
            --text-primary: #f1f5f9;
            --text-secondary: #94a3b8;
            --primary-cyan: #00f2fe;
            --primary-blue: #4facfe;
            --accent-glow: rgba(0, 242, 254, 0.4);
            --gradient-premium: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
            --gradient-dark: linear-gradient(180deg, #0a0f1d 0%, #070a14 100%);
            --font-main: 'Plus Jakarta Sans', sans-serif;
            --font-heading: 'Space Grotesk', sans-serif;
            --transition-smooth: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--bg-deep-navy);
            background-image: var(--gradient-dark);
            color: var(--text-primary);
            font-family: var(--font-main);
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* Utility Class for Glow Text */
        .text-glow {
            text-shadow: 0 0 20px var(--accent-glow);
        }

        /* ==========================================================================
           2. INTERACTIVE BACKGROUND (CANVAS)
           ========================================================================== */
        #bg-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 0;
            pointer-events: none;
        }

        /* ==========================================================================
           3. NAVBAR
           ========================================================================== */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            padding: 20px 5%;
            z-index: 1000;
            background: rgba(10, 15, 29, 0.7);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--border-glass);
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: var(--transition-smooth);
        }

        .navbar.scrolled {
            padding: 15px 5%;
            background: rgba(7, 10, 20, 0.9);
        }

        .logo-container {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        /* Custom Premium SVG Logo Element */
        .logo-icon {
            width: 45px;
            height: 45px;
            position: relative;
        }

        .logo-text {
            font-family: var(--font-heading);
            font-weight: 700;
            font-size: 1.25rem;
            color: var(--text-primary);
            letter-spacing: 0.5px;
        }

        .logo-text span {
            background: var(--gradient-premium);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-links {
            display: flex;
            gap: 25px;
            list-style: none;
            align-items: center;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text-secondary);
            font-size: 0.95rem;
            font-weight: 500;
            transition: var(--transition-smooth);
            position: relative;
            padding: 5px 0;
        }

        .nav-links a:hover, .nav-links a.active {
            color: var(--primary-cyan);
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--gradient-premium);
            transition: var(--transition-smooth);
        }

        .nav-links a:hover::after, .nav-links a.active::after {
            width: 100%;
        }

        .btn-whatsapp {
            background: #25d366;
            color: #fff !important;
            padding: 10px 20px !important;
            border-radius: 50px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 600 !important;
            box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
        }

        .btn-whatsapp:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(37, 211, 102, 0.5);
        }

        .btn-whatsapp::after {
            display: none !important;
        }

        .menu-toggle {
            display: none;
            color: var(--text-primary);
            font-size: 1.5rem;
            cursor: pointer;
        }

        /* ==========================================================================
           4. HERO SECTION
           ========================================================================== */
        .hero {
            min-height: 100vh;
            padding: 140px 5% 60px 5%;
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            align-items: center;
            gap: 40px;
            position: relative;
            z-index: 1;
        }

        .hero-content {
            max-width: 750px;
        }

        .hero-content h1 {
            font-family: var(--font-heading);
            font-size: 3.8rem;
            font-weight: 800;
            line-height: 1.15;
            margin-bottom: 20px;
        }

        .hero-content h1 span {
            background: var(--gradient-premium);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-content p {
            color: var(--text-secondary);
            font-size: 1.25rem;
            margin-bottom: 35px;
            font-weight: 400;
        }

        .hero-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 40px;
        }

        .btn-premium {
            background: var(--gradient-premium);
            color: #070a14;
            padding: 14px 28px;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
            transition: var(--transition-smooth);
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 20px rgba(0, 242, 254, 0.25);
        }

        .btn-premium:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 25px rgba(0, 242, 254, 0.45);
        }

        .btn-outline {
            background: rgba(255, 255, 255, 0.03);
            color: var(--text-primary);
            padding: 14px 28px;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
            transition: var(--transition-smooth);
            border: 1px solid var(--border-glass);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-outline:hover {
            background: rgba(0, 242, 254, 0.05);
            border-color: var(--primary-cyan);
            color: var(--primary-cyan);
        }

        /* Profile Card Glassmorphism */
        .profile-card {
            background: var(--bg-card-glass);
            border: 1px solid var(--border-glass);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 24px;
            padding: 30px;
            display: flex;
            align-items: center;
            gap: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            max-width: 450px;
            position: relative;
            overflow: hidden;
        }

        .profile-card::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(0,242,254,0.05) 0%, transparent 70%);
            pointer-events: none;
        }

        .profile-img-placeholder {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            border: 2px solid var(--primary-cyan);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: var(--primary-cyan);
            flex-shrink: 0;
            box-shadow: 0 0 15px rgba(0, 242, 254, 0.2);
        }

        .profile-info h3 {
            font-family: var(--font-heading);
            font-size: 1.4rem;
            margin-bottom: 4px;
        }

        .profile-info p {
            margin-bottom: 2px;
            font-size: 0.95rem;
        }

        .badge-premium {
            background: rgba(0, 242, 254, 0.1);
            border: 1px solid var(--primary-cyan);
            color: var(--primary-cyan);
            padding: 3px 10px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: inline-block;
            margin-top: 6px;
        }

        /* Hero Animation Visual */
        .hero-visual {
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
        }

        .illustration-container {
            width: 100%;
            max-width: 450px;
            height: 450px;
            background: radial-gradient(circle, rgba(7, 79, 254, 0.1) 0%, transparent 70%);
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* Interactive CSS Lab Flask & Orbit */
        .animated-flask {
            font-size: 7rem;
            background: var(--gradient-premium);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: floatFlask 4s ease-in-out infinite;
            z-index: 2;
        }

        .orbit-ring {
            position: absolute;
            border: 1px dashed rgba(0, 242, 254, 0.4);
            border-radius: 50%;
            animation: spin 15s linear infinite;
        }

        .ring-1 { width: 300px; height: 300px; transform: rotateX(70deg) rotateY(20deg); }
        .ring-2 { width: 350px; height: 350px; transform: rotateX(60deg) rotateY(-30deg); animation-duration: 20s; }

        @keyframes floatFlask {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-15px) rotate(3deg); }
        }

        @keyframes spin {
            100% { transform: rotate(360deg); }
        }

        /* ==========================================================================
           5. SECTION GENERAL STYLES
           ========================================================================== */
        section {
            padding: 100px 5%;
            position: relative;
            z-index: 1;
        }

        .section-header {
            text-align: center;
            max-width: 700px;
            margin: 0 auto 60px auto;
        }

        .section-header h2 {
            font-family: var(--font-heading);
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 15px;
        }

        .section-header h2 span {
            background: var(--gradient-premium);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .section-header p {
            color: var(--text-secondary);
            font-size: 1.1rem;
        }

        /* ==========================================================================
           6. ABOUT SECTION
           ========================================================================== */
        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 50px;
            align-items: center;
        }

        .about-stats-box {
            background: var(--bg-card-glass);
            border: 1px solid var(--border-glass);
            border-radius: 24px;
            padding: 40px;
            text-align: center;
        }

        .about-stats-box i {
            font-size: 4rem;
            background: var(--gradient-premium);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 20px;
        }

        .about-text h3 {
            font-family: var(--font-heading);
            font-size: 2rem;
            margin-bottom: 15px;
        }

        .about-text h3 span {
            color: var(--primary-cyan);
        }

        .about-text p {
            color: var(--text-secondary);
            margin-bottom: 30px;
            font-size: 1.05rem;
        }

        .about-features-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        .about-feat-card {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(255,255,255,0.02);
            padding: 15px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.05);
        }

        .about-feat-card i {
            color: var(--primary-cyan);
            font-size: 1.2rem;
        }

        /* ==========================================================================
           7. COURSES SECTION
           ========================================================================== */
        .grid-layout {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }

        .glass-card {
            background: var(--bg-card-glass);
            border: 1px solid var(--border-glass);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 35px 30px;
            transition: var(--transition-smooth);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .glass-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(180deg, rgba(0, 242, 254, 0.05) 0%, transparent 100%);
            opacity: 0;
            transition: var(--transition-smooth);
        }

        .glass-card:hover {
            transform: translateY(-5px);
            border-color: rgba(0, 242, 254, 0.4);
            box-shadow: 0 15px 35px rgba(0, 242, 254, 0.1);
        }

        .glass-card:hover::before {
            opacity: 1;
        }

        .card-icon {
            width: 60px;
            height: 60px;
            border-radius: 14px;
            background: rgba(0, 242, 254, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: var(--primary-cyan);
            margin-bottom: 25px;
        }

        .glass-card h3 {
            font-family: var(--font-heading);
            font-size: 1.4rem;
            margin-bottom: 12px;
        }

        .glass-card p {
            color: var(--text-secondary);
            font-size: 0.95rem;
            margin-bottom: 25px;
            flex-grow: 1;
        }

        /* ==========================================================================
           8. FREE NOTES, VIDEO LECTURES & MCQS (COMING SOON UX)
           ========================================================================== */
        .status-badge {
            position: absolute;
            top: 20px;
            right: 20px;
            background: rgba(245, 158, 11, 0.1);
            border: 1px solid #f59e0b;
            color: #f59e0b;
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
        }

        .btn-disabled {
            background: rgba(255,255,255,0.05);
            color: var(--text-secondary);
            border: 1px solid rgba(255,255,255,0.1);
            cursor: not-allowed;
            pointer-events: none;
        }

        /* ==========================================================================
           9. WHY CHOOSE US
           ========================================================================== */
        .why-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 25px;
        }

        .why-card {
            background: rgba(16, 24, 48, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-radius: 16px;
            padding: 30px;
            display: flex;
            gap: 20px;
            transition: var(--transition-smooth);
        }

        .why-card:hover {
            border-color: var(--border-glass);
            background: var(--bg-card-glass);
        }

        .why-card i {
            font-size: 1.8rem;
            color: var(--primary-cyan);
            flex-shrink: 0;
        }

        .why-card h4 {
            font-family: var(--font-heading);
            font-size: 1.2rem;
            margin-bottom: 8px;
        }

        .why-card p {
            color: var(--text-secondary);
            font-size: 0.95rem;
        }

        /* ==========================================================================
           10. GALLERY (MASONRY)
           ========================================================================== */
        .gallery-masonry {
            columns: 3 300px;
            column-gap: 20px;
        }

        .gallery-item {
            break-inside: avoid;
            margin-bottom: 20px;
            border-radius: 16px;
            overflow: hidden;
            position: relative;
            border: 1px solid var(--border-glass);
            background: #101830;
        }

        .gallery-placeholder {
            width: 100%;
            background: linear-gradient(135deg, #16223f 0%, #0d1527 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 60px 20px;
            text-align: center;
            color: var(--text-secondary);
            transition: var(--transition-smooth);
        }

        /* Dynamic heights for professional masonry effect */
        .h-small { min-height: 200px; }
        .h-medium { min-height: 280px; }
        .h-large { min-height: 360px; }

        .gallery-placeholder i {
            font-size: 2.5rem;
            color: var(--primary-cyan);
            margin-bottom: 15px;
            opacity: 0.7;
            transition: var(--transition-smooth);
        }

        .gallery-placeholder span {
            font-family: var(--font-heading);
            font-weight: 500;
            font-size: 1.1rem;
            color: var(--text-primary);
        }

        .gallery-placeholder p {
            font-size: 0.85rem;
            margin-top: 5px;
        }

        .gallery-item:hover .gallery-placeholder {
            transform: scale(1.03);
            background: linear-gradient(135deg, #1c2d55 0%, #101b33 100%);
        }

        .gallery-item:hover .gallery-placeholder i {
            transform: translateY(-5px);
            opacity: 1;
            color: var(--primary-blue);
        }

        /* ==========================================================================
           11. ADMISSIONS SECTION
           ========================================================================== */
        .admission-box {
            background: linear-gradient(135deg, rgba(0, 242, 254, 0.05) 0%, rgba(7, 79, 254, 0.05) 100%);
            border: 1px solid var(--border-glass);
            border-radius: 30px;
            padding: 60px 40px;
            text-align: center;
            max-width: 900px;
            margin: 0 auto;
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(10px);
        }

        .admission-box h3 {
            font-family: var(--font-heading);
            font-size: 2.2rem;
            margin-bottom: 15px;
        }

        .admission-box p {
            color: var(--text-secondary);
            max-width: 600px;
            margin: 0 auto 35px auto;
            font-size: 1.1rem;
        }

        .admission-actions {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        /* ==========================================================================
           12. CONTACT SECTION
           ========================================================================== */
        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 50px;
        }

        .contact-info {
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        .contact-method {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .contact-method .icon {
            width: 55px;
            height: 55px;
            border-radius: 12px;
            background: var(--bg-card-glass);
            border: 1px solid var(--border-glass);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            color: var(--primary-cyan);
        }

        .contact-method h5 {
            font-family: var(--font-heading);
            font-size: 1.1rem;
            margin-bottom: 4px;
        }

        .contact-method p {
            color: var(--text-secondary);
        }

        .map-placeholder {
            margin-top: 20px;
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid var(--border-glass);
            height: 200px;
            background: #101830;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-secondary);
            gap: 10px;
        }

        .contact-form {
            background: var(--bg-card-glass);
            border: 1px solid var(--border-glass);
            border-radius: 24px;
            padding: 40px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .form-group label {
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--text-secondary);
        }

        .form-group input, .form-group textarea {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border-glass);
            border-radius: 8px;
            padding: 14px;
            color: var(--text-primary);
            font-family: var(--font-main);
            font-size: 1rem;
            transition: var(--transition-smooth);
        }

        .form-group input:focus, .form-group textarea:focus {
            outline: none;
            border-color: var(--primary-cyan);
            background: rgba(0, 242, 254, 0.02);
            box-shadow: 0 0 10px rgba(0, 242, 254, 0.1);
        }

        /* ==========================================================================
           13. PREMIUM FOOTER
           ========================================================================== */
        footer {
            background: #060912;
            border-top: 1px solid var(--border-glass);
            padding: 80px 5% 30px 5%;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr;
            gap: 40px;
            margin-bottom: 60px;
        }

        .footer-brand p {
            color: var(--text-secondary);
            margin-top: 15px;
            max-width: 350px;
        }

        .footer-links h4 {
            font-family: var(--font-heading);
            font-size: 1.15rem;
            margin-bottom: 20px;
            position: relative;
        }

        .footer-links ul {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .footer-links a {
            text-decoration: none;
            color: var(--text-secondary);
            transition: var(--transition-smooth);
        }

        .footer-links a:hover {
            color: var(--primary-cyan);
            padding-left: 5px;
        }

        .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.05);
            padding-top: 30px;
            text-align: center;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        /* ==========================================================================
           14. RESPONSIVE MEDIA QUERIES
           ========================================================================== */
        @media (max-width: 1024px) {
            .hero {
                grid-template-columns: 1fr;
                text-align: center;
                padding-top: 160px;
            }
            .hero-content { margin: 0 auto; }
            .hero-buttons { justify-content: center; }
            .profile-card { margin: 0 auto; }
            .about-grid, .contact-grid { grid-template-columns: 1fr; }
            .about-stats-box { max-width: 400px; margin: 0 auto; }
        }

        @media (max-width: 768px) {
            .hero-content h1 { font-size: 2.5rem; }
            .menu-toggle { display: block; }
            .nav-links {
                position: absolute;
                top: 100%;
                left: 0;
